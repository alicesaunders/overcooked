class SentenceWordEmbeddings:
    def __init__(self,
                 dataset_name: str = "nuhuibrahim/recifine", 
                 split: str = "train", 
                 batch_size: int = 5,
                 use_stopword_removal: bool= True, 
                 testing: bool = False):
    
        self.dataset_dict = load_dataset(dataset_name)
        dataset = self.dataset_dict[split]

        # Testing only 
        if testing:
            dataset = dataset.select(range(batch_size))

        self.dataset = dataset

        self.use_stopword_removal = use_stopword_removal
        self.default_stopwords = stopwords.words('english')

        self.special_char_pattern = re.compile('[{}]'.format(re.escape(string.punctuation.replace('-', ''))))

    def remove_special_characters(self, text):
        return self.special_char_pattern.sub('', text)
    
    def remove_stopwords(self, text):
        words = text.split()
        filtered = [w for w in words if w not in self.default_stopwords]
        return ' '.join(filtered)
    
    def clean_text(self, text: str) -> str:

        text = text.strip()
        text = text.lower()
        text = self.remove_special_characters(text)

        if self.use_stopword_removal:
            text = self.remove_stopwords(text)

        text = re.sub(r'\s+', ' ', text).strip()
        return text
    
    def preprocess_texts(self, sentences:list[str]) -> list[str]:
        return [self.clean_text(s) for s in sentences]






