import re
import string
import torch
from nltk.corpus import stopwords
import tensorflow as tf
from datasets import load_dataset
from sentence_transformers import SentenceTransformer

## https://huggingface.co/datasets/nuhuibrahim/recifine
dataset = load_dataset("nuhuibrahim/recifine")

default_stopwords = stopwords.words('english')

class SentenceWordEmbeddings:
    def __init__(self,dataset_name: 
                 str = "nuhuibrahim/recifine", 
                 device: str = None,):
        self.dataset = load_dataset(dataset_name)

        if device is None:
            self.device = 'cuda' if torch.cuda.is_available() else 'cpu'
        else:
            self.device = device

        self.model = SentenceTransformer("sentence-transformers/all-MiniLM-L6-v2", device = self.device)
        print('Model loaded on {}'.format(self.device))


def clean_text(text):

    def remove_special_characters(text, characters=string.punctuation.replace('-', '')):
        pattern = re.compile('[{}]'.format(re.escape(characters)))
        return pattern.sub('', text)

    def remove_stopwords(text, stop_words=default_stopwords):
        pattern = r'\b(' + '|'.join(map(re.escape, stop_words)) + r')\b'
        return re.sub(pattern, '', text)

    text = text.strip()
    text = text.lower()
    text = remove_special_characters(text)
    text = remove_stopwords(text)
    text = re.sub(r'\s+', ' ', text).strip()

    return text

## Test - Start
test_dict = dataset['train'][1:5]
cleaned_sentences = [clean_text(sentence) for sentence in test_dict['ingredients']] 

# Load pre-trained model
model = SentenceTransformer("sentence-transformers/all-MiniLM-L6-v2")

# Calculate embeddings by calling model.encode()
embeddings = model.encode(cleaned_sentences)
print(embeddings.shape)
# [3, 384]

# Calculate the embedding similarities
similarities = model.similarity(embeddings, embeddings)
print(similarities)
